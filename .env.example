# In production, set VITE_API_URL to /api and configure your hosting platform
# (Nginx, Vercel, Railway, etc.) to proxy /api/* to your backend service.
# Never point this directly at the backend URL — keep the backend origin hidden.
VITE_API_URL=/api

# Backend proxy target — used by vite.config.ts during local dev only.
# Vite reads this at build/serve time (Node context), not in the browser.
# Change this to match wherever schwab-dackend is running locally.
API_TARGET=http://localhost:3002
